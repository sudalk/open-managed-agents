{
  "name": "open-managed-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./sdk": "./src/sdk/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev -c wrangler.jsonc -c sandbox-worker/wrangler.dev.jsonc",
    "dev:main": "wrangler dev --port 8787",
    "dev:sandbox": "cd sandbox-worker && wrangler dev --config wrangler.dev.jsonc --port 8788 --persist-to ../.wrangler/state",
    "dev:console": "cd console && npx vite",
    "build:console": "cd console && npx vite build",
    "deploy": "cd console && npx vite build && cd .. && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@cloudflare/sandbox": "^0.1.0",
    "ai": "^4.3.0",
    "hono": "^4.7.0",
    "nanoid": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.3",
    "wrangler": "^4.14.0"
  }
}
