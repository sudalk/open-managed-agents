{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "managed-agents-integrations",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  // Public origin where this gateway is reachable. Used to build OAuth
  // callback / webhook URLs the gateway hands to Linear. No trailing slash.
  // Override per env in [env.<name>] vars when deploying.
  "vars": {
    "GATEWAY_ORIGIN": "https://integrations.openma.dev"
  },

  // Keep the *.workers.dev URL alive alongside the custom domain — useful
  // for incident debugging when the zone is having issues.
  "workers_dev": true,

  // Custom Domain: Cloudflare auto-creates the DNS record + worker route
  // when this is in place. Requires openma.dev to be on this Cloudflare
  // account.
  "routes": [
    { "pattern": "integrations.openma.dev", "custom_domain": true }
  ],

  // Shared with apps/main. Migrations for integrations tables live with
  // packages/integrations-adapters-cf and are applied via the same D1 instance.
  "d1_databases": [
    { "binding": "AUTH_DB", "database_name": "openma-auth", "database_id": "67edb234-8ac8-4666-9252-7ce0bf35c20a" }
  ],

  // Service binding back to the main worker for session creation / resume.
  "services": [
    { "binding": "MAIN", "service": "managed-agents" }
  ],

  "observability": { "enabled": true },

  // Per-IP and per-tenant rate limit on webhook receivers. Public endpoints
  // (Linear / GitHub / Slack POST here unauthenticated and we sig-verify),
  // so an attacker can flood with garbage payloads (per-IP catches it) and
  // a misconfigured legit workspace can flood from real upstream IPs
  // (per-tenant catches that — applied AFTER sig verify exposes the tenant).
  // Soft-pass when binding absent (matches OSS / dev convention).
  "ratelimits": [
    { "name": "RL_WEBHOOK_IP",     "namespace_id": "3001", "simple": { "limit": 30, "period": 10 } },
    { "name": "RL_WEBHOOK_TENANT", "namespace_id": "3003", "simple": { "limit": 60, "period": 60 } }
  ],

  "env": {
    "staging": {
      "name": "managed-agents-integrations-staging",
      "vars": {
        "GATEWAY_ORIGIN": "https://integrations.staging.openma.dev"
      },
      "routes": [
        { "pattern": "integrations.staging.openma.dev", "custom_domain": true }
      ],
      "d1_databases": [
        { "binding": "AUTH_DB", "database_name": "openma-auth-staging", "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" }
      ],
      "services": [
        { "binding": "MAIN", "service": "managed-agents-staging" }
      ],
      "observability": { "enabled": true },
      "ratelimits": [
        { "name": "RL_WEBHOOK_IP",     "namespace_id": "3002", "simple": { "limit": 30, "period": 10 } },
        { "name": "RL_WEBHOOK_TENANT", "namespace_id": "3004", "simple": { "limit": 60, "period": 60 } }
      ]
    }
  }
}
