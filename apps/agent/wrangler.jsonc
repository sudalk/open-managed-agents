{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "sandbox-default",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile.sandbox",
      "instance_type": "basic",
      "max_instances": 50
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDO" },
      { "name": "SANDBOX", "class_name": "Sandbox" }
    ]
  },

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
  ],

  // D1 binding for memory store metadata (memory_stores / memories /
  // memory_versions tables) — agent's memory tools use the same shared
  // MemoryStoreService as the main worker, which requires direct D1 access.
  "d1_databases": [
    { "binding": "AUTH_DB", "database_name": "openma-auth", "database_id": "dbb5f01c-7016-4157-945d-f8ff9fbda967" }
  ],

  // Service binding to the integrations gateway. Used by the outbound proxy
  // to refresh short-lived upstream tokens (e.g. GitHub installation tokens,
  // ~1hr TTL) on 401. The agent worker never sees provider secrets directly
  // — it just asks the gateway "please refresh credential X" and the gateway
  // does the App-JWT signing using its locally-held private key.
  // MAIN binding lets AcpProxyHarness call /v1/internal/runtime-attach-harness
  // to reach the RuntimeRoom DO (where the user's `oma bridge daemon` is wired).
  "services": [
    { "binding": "INTEGRATIONS", "service": "managed-agents-integrations" },
    { "binding": "MAIN", "service": "managed-agents" }
  ],

  // Workers AI for generating embeddings
  "ai": { "binding": "AI" },

  // Vectorize for semantic memory search
  "vectorize": [
    { "binding": "VECTORIZE", "index_name": "memory-search" }
  ],

  // Resolved bucket names per env — sandbox.ts FUSE mode mounts via the
  // S3 API which takes the actual bucket name (not the binding name).
  // Keep these in sync with r2_buckets[].bucket_name above. Override in
  // env.staging for staging-specific bucket names.
  // CLOUDFLARE_ACCOUNT_ID + BACKUP_BUCKET_NAME are required by sandbox
  // SDK createBackup() to mint R2 presigned URLs for the squashfs upload
  // (production mode). Keep these in sync across env overrides.
  "vars": {
    "MEMORY_BUCKET_NAME": "managed-agents-memory",
    "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
    "BACKUP_BUCKET_NAME": "managed-agents-backups",
    "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
  },

  "r2_buckets": [
    { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
    { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
    // Required by @cloudflare/sandbox createBackup/restoreBackup. Holds
    // the squashfs archives the BaseSnapshotStrategy persists per env.
    // The SDK looks for the binding by the literal name BACKUP_BUCKET.
    { "binding": "BACKUP_BUCKET", "bucket_name": "managed-agents-backups" },
    // Memory store content. Mounted into the sandbox per attached store via
    // sandbox.mountBucket(<bucket-name>, "/mnt/memory/<store_name>",
    //   { endpoint+credentials+provider:"r2", prefix: "/<store_id>/", readOnly })
    // Agent reads/writes via standard file tools; writes propagate to R2 then
    // feed the apps/main MEMORY queue consumer for D1 audit.
    { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory" }
  ],

  "browser": { "binding": "BROWSER" },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true },

  // Analytics Engine for structured error/event metrics from the agent
  // worker (SessionDO, outbound proxy, sandbox lifecycle). Same dataset as
  // the main worker so dashboards see all OMA events together.
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "oma_events" }
  ],

  // Staging twin: a fully separate sandbox-default-staging worker bound to
  // the staging KV / D1 / R2 / DO namespace. Keeps prod and staging session
  // state and tenant data fully isolated. The staging main worker's
  // SANDBOX_sandbox_default service binding points at "sandbox-default-staging".
  "env": {
    "staging": {
      "name": "sandbox-default-staging",
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile.sandbox",
          "instance_type": "basic",
          "max_instances": 50
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDO" },
          { "name": "SANDBOX", "class_name": "Sandbox" }
        ]
      },
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "f91ddab8abe64941bd3ef398b0c187a7" }
      ],
      "d1_databases": [
        { "binding": "AUTH_DB", "database_name": "openma-auth-staging", "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" }
      ],
      "services": [
        { "binding": "INTEGRATIONS", "service": "managed-agents-integrations-staging" },
        { "binding": "MAIN", "service": "managed-agents-staging" }
      ],
      "ai": { "binding": "AI" },
      "vectorize": [
        { "binding": "VECTORIZE", "index_name": "memory-search" }
      ],
      "vars": {
        "MEMORY_BUCKET_NAME": "managed-agents-memory-staging",
        "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
        "BACKUP_BUCKET_NAME": "managed-agents-backups",
        "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
      },
      "r2_buckets": [
        { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
        { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
        { "binding": "BACKUP_BUCKET", "bucket_name": "managed-agents-backups" },
        { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory-staging" }
      ],
      "browser": { "binding": "BROWSER" },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "oma_events_staging" }
      ]
    }
  }
}
