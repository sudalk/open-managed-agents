{
  "name": "@openma/cli",
  "version": "0.1.0-beta.2",
  "description": "CLI for the openma managed agents platform",
  "type": "module",
  "bin": {
    "oma": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["ai", "agents", "managed-agents", "openma", "cli", "llm"],
  "license": "MIT",
  "homepage": "https://openma.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-ma/open-managed-agents",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/open-ma/open-managed-agents/issues"
  },
  "devDependencies": {
    "@open-managed-agents/api-types": "workspace:*",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0"
  }
}
