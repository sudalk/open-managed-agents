{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "sandbox-__ENV_ID__",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 10
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDO" },
      { "name": "SANDBOX", "class_name": "Sandbox" }
    ]
  },

  // Share the same KV namespace as the main worker
  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "__KV_ID__" }
  ],

  // SessionDO reads agent / environment / session / credential rows from
  // the same D1 the main worker uses; without this binding every
  // services.*.get() call hits "Cannot read properties of undefined
  // (reading 'prepare')" on db.prepare().
  "d1_databases": [
    { "binding": "AUTH_DB", "database_name": "openma-auth", "database_id": "dbb5f01c-7016-4157-945d-f8ff9fbda967" }
  ],

  // Outbound proxy on-401 token refresh path delegates to the integrations
  // gateway (App-JWT signing for GitHub installation tokens etc.). Without
  // this binding, refreshes silently no-op.
  // MAIN binding lets AcpProxyHarness call /v1/internal/runtime-attach-harness
  // to reach the RuntimeRoom DO (where the user's `oma bridge daemon` is wired).
  "services": [
    { "binding": "INTEGRATIONS", "service": "managed-agents-integrations" },
    { "binding": "MAIN", "service": "managed-agents" }
  ],

  // Workers AI for embedding generation (memory tools).
  "ai": { "binding": "AI" },

  // Vectorize index used by semantic memory search.
  "vectorize": [
    { "binding": "VECTORIZE", "index_name": "memory-search" }
  ],

  "vars": {
    "MEMORY_BUCKET_NAME": "managed-agents-memory",
    "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
    "BACKUP_BUCKET_NAME": "managed-agents-backups",
    "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
  },

  "r2_buckets": [
    { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
    { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
    { "binding": "BACKUP_BUCKET", "bucket_name": "managed-agents-backups" },
    // Memory store mount target — see apps/agent/wrangler.jsonc comment.
    { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory" }
  ],

  "browser": { "binding": "BROWSER" },

  // Analytics Engine — same dataset as main worker so dashboards see
  // events from per-env sandboxes alongside the shared sandbox.
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "oma_events" }
  ],

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true }
}
