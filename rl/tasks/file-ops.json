{
  "name": "file-ops",
  "version": "0.1.0",
  "tasks": [
    {
      "id": "file-01-create-text",
      "description": "Create a plain text file with specific content",
      "message": "Create a file at /workspace/hello.txt containing exactly: Hello, World!",
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_exists", "path": "/workspace/hello.txt", "score": 0.3 },
          { "check": "file_contains", "path": "/workspace/hello.txt", "expected": "Hello, World!", "score": 0.7 }
        ]
      }
    },
    {
      "id": "file-02-create-json",
      "description": "Create a JSON config file",
      "message": "Create a file at /workspace/config.json with this exact JSON content: {\"host\": \"localhost\", \"port\": 8080, \"debug\": false}",
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_exists", "path": "/workspace/config.json", "score": 0.2 },
          { "check": "file_contains", "path": "/workspace/config.json", "expected": "\"port\": 8080", "score": 0.4 },
          { "check": "file_contains", "path": "/workspace/config.json", "expected": "\"debug\": false", "score": 0.4 }
        ]
      }
    },
    {
      "id": "file-03-create-csv",
      "description": "Create a CSV data file",
      "message": "Create a file at /workspace/data.csv with this content:\nname,age,city\nAlice,30,NYC\nBob,25,LA\nCharlie,35,Chicago",
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_exists", "path": "/workspace/data.csv", "score": 0.2 },
          { "check": "file_contains", "path": "/workspace/data.csv", "expected": "Alice,30,NYC", "score": 0.4 },
          { "check": "file_contains", "path": "/workspace/data.csv", "expected": "Charlie,35,Chicago", "score": 0.4 }
        ]
      }
    },
    {
      "id": "file-04-edit-replace",
      "description": "Edit a file to replace a value",
      "message": "Read the file /workspace/config.json, then change the port from 8080 to 3000 using the edit tool.",
      "setup_files": [
        { "path": "/workspace/config.json", "content": "{\"host\": \"localhost\", \"port\": 8080, \"debug\": false}" }
      ],
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_contains", "path": "/workspace/config.json", "expected": "3000", "score": 0.6 },
          { "check": "file_contains", "path": "/workspace/config.json", "expected": "localhost", "score": 0.4 }
        ]
      }
    },
    {
      "id": "file-05-create-nested",
      "description": "Create files in nested directories",
      "message": "Create the following files:\n/workspace/src/index.ts with content: export const main = () => console.log('hello');\n/workspace/src/utils/helper.ts with content: export const add = (a: number, b: number) => a + b;",
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_exists", "path": "/workspace/src/index.ts", "score": 0.25 },
          { "check": "file_contains", "path": "/workspace/src/index.ts", "expected": "main", "score": 0.25 },
          { "check": "file_exists", "path": "/workspace/src/utils/helper.ts", "score": 0.25 },
          { "check": "file_contains", "path": "/workspace/src/utils/helper.ts", "expected": "add", "score": 0.25 }
        ]
      }
    },
    {
      "id": "file-06-grep-filter",
      "description": "Use grep to find matching lines in a file",
      "message": "Use the grep tool to find all lines containing 'error' (case-insensitive) in /workspace/app.log. Report the matching lines.",
      "setup_files": [
        { "path": "/workspace/app.log", "content": "2024-01-01 INFO: Server started\n2024-01-01 ERROR: Connection failed\n2024-01-01 INFO: Retrying...\n2024-01-01 ERROR: Timeout exceeded\n2024-01-01 INFO: Server stopped" }
      ],
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "bash_output_contains", "expected": "Connection failed", "score": 0.5 },
          { "check": "bash_output_contains", "expected": "Timeout exceeded", "score": 0.5 }
        ]
      }
    },
    {
      "id": "file-07-glob-find",
      "description": "Use glob to find files by pattern",
      "message": "Use the glob tool to find all .ts files under /workspace/src/. List all matches.",
      "setup_files": [
        { "path": "/workspace/src/index.ts", "content": "// entry" },
        { "path": "/workspace/src/utils.ts", "content": "// utils" },
        { "path": "/workspace/src/tests/test.ts", "content": "// test" },
        { "path": "/workspace/src/readme.md", "content": "# readme" }
      ],
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "bash_output_contains", "expected": "index.ts", "score": 0.33 },
          { "check": "bash_output_contains", "expected": "utils.ts", "score": 0.33 },
          { "check": "bash_output_contains", "expected": "test.ts", "score": 0.34 }
        ]
      }
    },
    {
      "id": "file-08-read-transform",
      "description": "Read a file and write a transformed version",
      "message": "Read /workspace/names.txt. Create /workspace/names_upper.txt with all names converted to uppercase, one per line.",
      "setup_files": [
        { "path": "/workspace/names.txt", "content": "alice\nbob\ncharlie" }
      ],
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_exists", "path": "/workspace/names_upper.txt", "score": 0.2 },
          { "check": "file_contains", "path": "/workspace/names_upper.txt", "expected": "ALICE", "score": 0.3 },
          { "check": "file_contains", "path": "/workspace/names_upper.txt", "expected": "BOB", "score": 0.2 },
          { "check": "file_contains", "path": "/workspace/names_upper.txt", "expected": "CHARLIE", "score": 0.3 }
        ]
      }
    },
    {
      "id": "file-09-multi-edit",
      "description": "Make multiple edits to a file",
      "message": "Edit /workspace/config.yaml: change 'debug: true' to 'debug: false' and change 'port: 3000' to 'port: 9090'.",
      "setup_files": [
        { "path": "/workspace/config.yaml", "content": "server:\n  host: localhost\n  port: 3000\n  debug: true\n  workers: 4" }
      ],
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_contains", "path": "/workspace/config.yaml", "expected": "debug: false", "score": 0.4 },
          { "check": "file_contains", "path": "/workspace/config.yaml", "expected": "port: 9090", "score": 0.4 },
          { "check": "file_contains", "path": "/workspace/config.yaml", "expected": "workers: 4", "score": 0.2 }
        ]
      }
    },
    {
      "id": "file-10-create-script",
      "description": "Create a Python script and verify it runs",
      "message": "Create a Python script at /workspace/greet.py that takes a name as a command-line argument and prints 'Hello, {name}!'. Then run it with: python3 /workspace/greet.py World",
      "reward": {
        "type": "rule",
        "rules": [
          { "check": "file_exists", "path": "/workspace/greet.py", "score": 0.3 },
          { "check": "bash_output_contains", "expected": "Hello, World!", "score": 0.5 },
          { "check": "exit_code", "expected": "0", "score": 0.2 }
        ]
      }
    }
  ]
}
