{
  "name": "@openma/sdk",
  "version": "0.1.0-beta.1",
  "description": "Official TypeScript SDK for the openma managed agents platform — typed REST + SSE streaming.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["ai", "agents", "managed-agents", "openma", "sdk", "llm", "streaming", "sse"],
  "license": "MIT",
  "homepage": "https://openma.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-ma/open-managed-agents",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/open-ma/open-managed-agents/issues"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
