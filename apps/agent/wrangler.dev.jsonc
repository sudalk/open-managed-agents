{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "sandbox-default",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-15",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "../../node_modules/@cloudflare/sandbox/Dockerfile",
      "instance_type": "lite",
      "max_instances": 5
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDO" },
      { "name": "SANDBOX", "class_name": "Sandbox" }
    ]
  },

  // Same KV as main worker — share agent/env/session config
  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
  ],

  "vars": {
    "MEMORY_BUCKET_NAME": "managed-agents-memory",
    "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
    "BACKUP_BUCKET_NAME": "managed-agents-backups",
    "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
  },

  "r2_buckets": [
    { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
    { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
    // Memory store mount target. In wrangler dev this resolves to the local
    // wrangler R2 simulator; sandbox.mountBucket(..., { localBucket: true })
    // performs bidirectional sync via the binding.
    { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory" }
  ],

  // MAIN service binding so AcpProxyHarness can call into the main worker's
  // /v1/internal/runtime-attach-harness endpoint to reach RuntimeRoom DO.
  "services": [
    { "binding": "MAIN", "service": "managed-agents" }
  ],

  "browser": { "binding": "BROWSER" },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true }
}
