{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "sandbox-default",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-15",
  "compatibility_flags": ["nodejs_compat"],

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile.sandbox",
      "instance_type": "basic",
      "max_instances": 10
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDO" },
      { "name": "SANDBOX", "class_name": "Sandbox" }
    ]
  },

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
  ],

  // Service binding to the integrations gateway. Used by the outbound proxy
  // to refresh short-lived upstream tokens (e.g. GitHub installation tokens,
  // ~1hr TTL) on 401. The agent worker never sees provider secrets directly
  // — it just asks the gateway "please refresh credential X" and the gateway
  // does the App-JWT signing using its locally-held private key.
  "services": [
    { "binding": "INTEGRATIONS", "service": "managed-agents-integrations" }
  ],

  // Workers AI for generating embeddings
  "ai": { "binding": "AI" },

  // Vectorize for semantic memory search
  "vectorize": [
    { "binding": "VECTORIZE", "index_name": "memory-search" }
  ],

  "r2_buckets": [
    { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
    { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" }
  ],

  "browser": { "binding": "BROWSER" },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true },

  // Staging twin: a fully separate sandbox-default-staging worker bound to
  // the staging KV / D1 / R2 / DO namespace. Keeps prod and staging session
  // state and tenant data fully isolated. The staging main worker's
  // SANDBOX_sandbox_default service binding points at "sandbox-default-staging".
  "env": {
    "staging": {
      "name": "sandbox-default-staging",
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile.sandbox",
          "instance_type": "basic",
          "max_instances": 10
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDO" },
          { "name": "SANDBOX", "class_name": "Sandbox" }
        ]
      },
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "f91ddab8abe64941bd3ef398b0c187a7" }
      ],
      "services": [
        { "binding": "INTEGRATIONS", "service": "managed-agents-integrations-staging" }
      ],
      "ai": { "binding": "AI" },
      "vectorize": [
        { "binding": "VECTORIZE", "index_name": "memory-search" }
      ],
      "r2_buckets": [
        { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
        { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" }
      ],
      "browser": { "binding": "BROWSER" },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true }
    }
  }
}
