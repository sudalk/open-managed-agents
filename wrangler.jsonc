{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "managed-agents",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "console/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "rules": [
    { "type": "Text", "globs": ["**/*.html"], "fallthrough": true }
  ],

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
  ],

  // DinD builder container — builds and deploys per-environment sandbox workers
  "durable_objects": {
    "bindings": [
      { "name": "BUILDER_SANDBOX", "class_name": "BuilderSandbox" }
    ]
  },

  "containers": [
    {
      "class_name": "BuilderSandbox",
      "image": "./builder/Dockerfile",
      "instance_type": "lite",
      "max_instances": 3
    }
  ],

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BuilderSandbox"]
    }
  ],

  // Service bindings to sandbox workers.
  // Local dev: declared here for the default sandbox worker.
  // Production: deploy.sh generates this list from KV svcbind:* entries.
  "services": [
    { "binding": "SANDBOX_sandbox_default", "service": "sandbox-default" }
  ],

  "limits": { "cpu_ms": 300000 },

  "observability": { "enabled": true }
}
